#!/usr/bin/make -f

%:
	dh $@ --with python3,systemd

override_dh_auto_install:
	dh_auto_install
	
	# Install daemon script
	install -d $(CURDIR)/debian/openmediavault-uartdisplay/usr/sbin
	install -m 0755 $(CURDIR)/usr/sbin/uartdisplayd.py $(CURDIR)/debian/openmediavault-uartdisplay/usr/sbin/
	
	# Install systemd service
	install -d $(CURDIR)/debian/openmediavault-uartdisplay/etc/systemd/system
	install -m 0644 $(CURDIR)/etc/systemd/system/uartdisplay.service $(CURDIR)/debian/openmediavault-uartdisplay/etc/systemd/system/
	
	# Install configuration file
	install -d $(CURDIR)/debian/openmediavault-uartdisplay/etc/openmediavault
	install -m 0644 $(CURDIR)/etc/openmediavault/uartdisplay.conf $(CURDIR)/debian/openmediavault-uartdisplay/etc/openmediavault/
	
	# Install documentation
	install -d $(CURDIR)/debian/openmediavault-uartdisplay/usr/share/doc/openmediavault-uartdisplay
	install -m 0644 $(CURDIR)/usr/share/doc/openmediavault-uartdisplay/README.md $(CURDIR)/debian/openmediavault-uartdisplay/usr/share/doc/openmediavault-uartdisplay/

override_dh_systemd_enable:
	dh_systemd_enable --name=uartdisplay

override_dh_systemd_start:
	dh_systemd_start --name=uartdisplay

override_dh_fixperms:
	dh_fixperms
